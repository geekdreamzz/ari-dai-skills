# Dataspheres AI credentials
# Copy this file to .env and fill in your values.
# .env is gitignored — your key stays local and never goes into chat history.

# Get your API key: https://dataspheres.ai/app/developers?tab=keys
DATASPHERES_API_KEY=dsk_your_key_here

# API host (where REST calls go). Leave as-is for production.
# Override only when running a local dev server (e.g. http://localhost:5173).
DATASPHERES_BASE_URL=https://dataspheres.ai

# Public/dashboard host (used to build user-facing links). Leave as-is for production.
DATASPHERES_PUBLIC_URL=https://dataspheres.ai
