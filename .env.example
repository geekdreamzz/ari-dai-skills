# Dataspheres AI credentials
# Copy this file to .env and fill in your values.
# .env is gitignored — your key stays local and never goes into chat history.

# Get your API key: dataspheres.ai → any datasphere → Settings → Developers → New Key
DATASPHERES_API_KEY=dsk_your_key_here

# Leave this as-is unless you're running a local dev server
DATASPHERES_BASE_URL=https://dataspheres.ai

# Your default workspace — the slug in the URL: dataspheres.ai/app/my-workspace-uri/...
DATASPHERES_DEFAULT_URI=my-workspace-uri
